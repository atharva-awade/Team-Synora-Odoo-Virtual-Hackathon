# Supabase Postgres. Get these from: Supabase dashboard -> Settings -> Database -> Connection string.
# If the DB password has special characters (@ : / etc.) URL-encode them (@ becomes %40).
# App connection: transaction pooler, port 6543, pgbouncer.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Migrations connection: session pooler, port 5432.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# Auth: any long random string.
JWT_SECRET="change-me-to-a-long-random-string"
